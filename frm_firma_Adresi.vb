            Dim frm As New frm_tbAlisVerisAdres
            frm.firmano = firmano
            frm.donemno = donemno
            frm.connection = connection
            frm.bAdres = True
            frm.nStokFisiID = dr("nAdresID")
            frm.nFirmaID = dr("nFirmaID")
            'Firma Ań²klamas² Kontrol
            If yetki_kontrol(kullanici, frm.Name) = True Then
                frm.ShowDialog()
                dataload()
            End If
        End If
