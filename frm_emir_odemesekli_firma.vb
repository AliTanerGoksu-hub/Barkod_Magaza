    Private Sub odemesekilleri_kontrol()
        ds_odemesekilleri = sorgu_odemesekilleri("")
        Dim dr1 As DataRow
        For Each dr1 In ds_odemesekilleri.Tables(0).Rows
            odemesekli_baglanti_kaydet_yeni(dr1("sOdemeSekli"), dr1("sAciklama"), dr1("nOdemeTipi"), 0)
        Next
    End Sub
    Public Function STOK() As DataSet
        Dim kriter As String = ""
        'kriter = "WHERE tbMusteri.dteKayitTarihi between '" & Microsoft.VisualBasic.Left(tarih1.ToString, 10) + " 00:00:00" & "' and '" & Microsoft.VisualBasic.Left(tarih1.ToString, 10) + " 23:59:59" & "' "
        Dim conn As New OleDb.OleDbConnection
        Dim cmd As New OleDb.OleDbCommand
        Dim adapter As New OleDb.OleDbDataAdapter
        conn.ConnectionString = connection
        cmd.CommandTimeout = False
        adapter.SelectCommand = cmd
        cmd.CommandText = sorgu_query("SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED SELECT aEmirOdemeSekliFirma.sOdemeSekli, aEmirOdemeSekliFirma.sAciklama, aEmirOdemeSekliFirma.nOdemeTipi, aEmirOdemeSekliFirma.nFirmaID, tbFirma.sKodu AS FIRMAKODU, tbFirma.sAciklama AS FIRMAADI, KtbFirma.nFirmaID AS KnFirmaID, KtbFirma.sKodu AS KFIRMAKODU, KtbFirma.sAciklama AS KFIRMAADI FROM aEmirOdemeSekliFirma LEFT OUTER JOIN tbFirma KtbFirma ON aEmirOdemeSekliFirma.KnFirmaID = KtbFirma.nFirmaID LEFT OUTER JOIN tbFirma ON aEmirOdemeSekliFirma.nFirmaID = tbFirma.nFirmaID")
        cmd.Connection = conn
        conn.Open()
        Dim Datastoklar1 As New DataSet
        Dim N As Integer = adapter.Fill(Datastoklar1, "TABLE1")
        conn.Close()
        Return Datastoklar1
    End Function
    Private Function sorgu_odemesekilleri(ByVal kriter As String) As DataSet
        Dim con As New OleDb.OleDbConnection
        Dim cmd As New OleDb.OleDbCommand
        Dim adapter As New OleDb.OleDbDataAdapter
        con.ConnectionString = connection
        cmd.CommandTimeout = Nothing
        adapter.SelectCommand = cmd
        cmd.CommandText = sorgu_query("SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED SELECT     *  FROM         tbOdemeSekli WHERE     (sOdemeSekli NOT IN (SELECT     sOdemeSekli FROM          aEmirOdemeSekliFirma))")
        cmd.Connection = con
        con.Open()
        Dim DS As New DataSet
        Dim N As Integer = adapter.Fill(DS, "BASLIK")
        con.Close()
        Return DS
    End Function
    Private Sub odemesekli_baglanti_kaydet_yeni(ByVal sOdemeSekli As String, ByVal sAciklama As String, ByVal nOdemeTipi As Int64, ByVal nFirmaID As String)
        Dim con As New OleDb.OleDbConnection
        Dim cmd As New OleDb.OleDbCommand
        cmd.Connection = con
        con.ConnectionString = connection
        cmd.CommandTimeout = Nothing
        If con.State = ConnectionState.Closed = True Then
            con.Open()
        End If
        cmd.CommandText = sorgu_query("SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED INSERT INTO aEmirOdemeSekliFirma                       (sOdemeSekli, sAciklama, nOdemeTipi, nFirmaID) VALUES     ('" & sOdemeSekli & "', N'" & sAciklama & "', '" & nOdemeTipi & "', '" & nFirmaID & "')")
        cmd.ExecuteNonQuery()
        con.Close()
    End Sub
    Private Sub odemesekli_baglanti_kaydet_degistir(ByVal sOdemeSekli As String, ByVal nFirmaID As String, Optional ByVal kesinti As Boolean = False)
        Dim con As New OleDb.OleDbConnection
        Dim cmd As New OleDb.OleDbCommand
        cmd.Connection = con
        con.ConnectionString = connection
        cmd.CommandTimeout = Nothing
        If con.State = ConnectionState.Closed = True Then
            con.Open()
        End If
        If kesinti = True Then
            cmd.CommandText = sorgu_query("SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED UPDATE    aEmirOdemeSekliFirma SET              KnFirmaID ='" & nFirmaID & "' where sOdemeSekli = '" & sOdemeSekli & "'")
        Else
            cmd.CommandText = sorgu_query("SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED UPDATE    aEmirOdemeSekliFirma SET              nFirmaID ='" & nFirmaID & "' where sOdemeSekli = '" & sOdemeSekli & "'")
        End If
        cmd.ExecuteNonQuery()
        con.Close()
    End Sub
