                kriter += "AND tbStok.nStokID IN (SELECT    tbStokSinifi.nStokID FROM           tbStokSinifi INNER JOIN tbSSinif10 ON tbStokSinifi.sSinifKodu10 = tbSSinif10.sSinifKodu WHERE tbSSinif10.sAciklama " & sorgu_kriter_string(ara, ara_kriter) & ")"
