            End Try
        Else
        End If
        If Trim(sFiyat1) = "" Then
            sFiyat1 = "1"
        End If
        If Trim(sFiyat2) = "" Then
            sFiyat2 = "2"
        End If
        If Trim(sFiyat3) = "" Then
            sFiyat3 = "3"
        End If
        If Trim(sFiyatA) = "" Then
            sFiyatA = "A"
        End If
        If Trim(sFiyatM) = "" Then
            sFiyatM = "M"
        End If
        If Trim(sKrediliFiyat) = "" Then
            sKrediliFiyat = "1"
        End If
        If Trim(sPesinFiyat) = "" Then
            sPesinFiyat = "1"
        End If
        If Trim(sDepo) = "" Then
            sDepo = "D001"
        End If
        If Trim(sSubeMagaza) = "" Then
            sSubeMagaza = "001"
        End If
    End Sub
    Private Sub NamazVaktiKontrol_eski()
        'dsDoviz.ReadXml("http://www.namazvaktim.com/xml/aylik/malatya.xml")
        Dim dosya As New FileInfo("c:\formlar\" & sIl & ".xml")
        If dosya.Exists Then
            dsNamazVakti.ReadXml("C:\FORMLAR\" & sIl & ".XML")
            Dim dr As DataRow
            Dim dr1 As DataRow = dsNamazVakti.Tables(0).Rows(0)
            Group_NamazVakti.Text = dr1(0) & " ili için Namaz Vakitleri"
            For Each dr In dsNamazVakti.Tables(1).Rows
                dr(0) = Replace(dr(0), " ", ":")
                dr(1) = Replace(dr(1), " ", ":")
                dr(2) = Replace(dr(2), " ", ":")
                dr(3) = Replace(dr(3), " ", ":")
                dr(4) = Replace(dr(4), " ", ":")
                dr(5) = Replace(dr(5), " ", ":")
                dr(6) = Replace(dr(6), " ", ":")
                dr(7) = Replace(dr(7), ".", "/")
            Next
            Dim gun As Integer = Today.Day.ToString
            'GridControl1.DataSource = dsDoviz.Tables(1)
            'GridControl1.FocusedRecord = gun - 1
            For Each dr In dsNamazVakti.Tables(1).Rows
                If dr(7) = dteSistemTarihi Then
                    lbl_imsak.Text = dr(0)
                    lbl_gunes.Text = dr(1)
                    lbl_ogle.Text = dr(2)
                    lbl_ikindi.Text = dr(3)
                    lbl_aksam.Text = dr(4)
                    lbl_yatsi.Text = dr(5)
                End If
            Next
        End If
        If lbl_imsak.Text = "*" Then
            Try
                dsNamazVakti.Clear()
            Catch ex As Exception
            End Try
            If sIl = "Kahraman Maraş" Then
                dsNamazVakti.ReadXml("http://www.namazvaktim.com/xml/aylik/Kahramanmaras.xml")
                Dim dosya1 As New FileInfo("c:\formlar\Kahramanmaras.xml")
                If dosya1.Exists Then
                    dosya1.Delete()
                End If
                dsNamazVakti.WriteXml("c:\formlar\Kahramanmaras.xml")
                NamazVaktiKontrol()
            Else
                dsNamazVakti.ReadXml("http://www.namazvaktim.com/xml/aylik/" & sIl & ".xml")
                Dim dosya1 As New FileInfo("c:\formlar\" & sIl & ".xml")
                If dosya1.Exists Then
                    dosya1.Delete()
                End If
                dsNamazVakti.WriteXml("c:\formlar\" & sIl & ".xml")
                NamazVaktiKontrol()
            End If
        End If
    End Sub
    Private Sub HadisKontrol()
        If Today.Day = 1 Then
            lbl_Hadis.Text = "Mü'minin başka hiç kimsede bulunmayan ilginç bir hali vardır; O'nun her işi hayırdır. Eğer bir genişliğe (nimete) kavuşursa şükreder ve bu onun için bir hayır olur. Eğer bir darlığa (musibete) uğrarsa sabreder ve bu da onun için bir hayır olur. "
            lbl_Ayet.Text = "Ey İnananlar! Sabredin, düşmanlarınızdan daha sabırlı olun, cihada hazır bulunun, Allah'a karşı gelmekten sakının ki başarıya erişebilesiniz. (Âl-i İmran, 200)"
            lbl_Dua.Text = "Bize rahmetinle, şerefinle, bereketinle muamele eyle."
        ElseIf Today.Day = 2 Then
            lbl_Hadis.Text = "Allah, her işte ihsanı (güzel davranmayı) emretmiştir."
            lbl_Ayet.Text = "Şüphesiz peygamberlerimize ve iman edenlere, hem dünya hayatında, hem şahitlerin şahitlik edecekleri günde yardım ederiz. (Mü'min, 51)"
            lbl_Dua.Text = "Topraklar altında hak ile yeksan olmuş, dünyada kimi kimsesi kalmamışların ruhlarını da hissedar eyle."
        ElseIf Today.Day = 3 Then
            lbl_Hadis.Text = "Kul bir günah işlediği zaman kalbinde siyah bir nokta oluşur. Bundan vazgeçip tövbe ve istiğfar ettiği zaman kalbi parlar. Günahtan dönmez ve bunu yapmaya devam ederse siyah nokta artırılır ve sonunda tüm kalbini kaplar. Allah’ın (Kitabında) ‘Hayır! Doğrusu onların kazanmakta oldukları kalplerini paslandırmıştır."
            lbl_Ayet.Text = "İman edip de iyi davranışlarda bulunanlara gelince, onlar için çok merhametli olan Allah, (gönüllerde) bir sevgi yaratacaktır. (Meryem Suresi, 96)"
            lbl_Dua.Text = "Bizi kötülükten uzaklaştıran ve kendisi de kötülükten uzak duranlardan eyle. Bize daima helal olan şeyleri nasib et ki, harama düşmeyelim. İbadet ve taatınla meşgul olmayı nasib et ki, günah ve isyana düşmeyelim. Lütuf ve ihsanını esirgeme ki, senden başkasına muhtaç olmayalım ya Rabbi."
        ElseIf Today.Day = 4 Then
            lbl_Hadis.Text = "Mümin, yeşil ekine benzer. Rüzgâr hangi taraftan eserse onu o tarafa yatırır (fakat yıkılmaz), rüzgâr sakinleştiğinde yine doğrulur. İşte mümin de böyledir; o, bela ve musibetler sebebiyle eğilir (fakat yıkılmaz). Kâfir ise sert ve dimdik selvi ağacına benzer ki Allah onu dilediği zaman (bir defada) söküp devirir."
            lbl_Ayet.Text = "De ki: Eğer (haktan) saparsam, kendi aleyhime sapmış olurum. Eğer doğru yolu bulursam, bu da Rabbimin bana vahyettiği (Kur'an) sayesindedir. Şüphesiz O, işitendir, yakındır. (Sebe', 50)"
            lbl_Dua.Text = "Yâ Rabbî! Bana hayırlı işler yapmak, çirkin şeyleri terk etmek ve fakirleri sevmek nasip eyle! Kavmim arasında fitne çıkacağı zaman, fitneye karışmadan canımı al! Ya Rabbi, bana sevgini, seni sevenlerin sevgisini, sevgine yaklaştıracak amellerin sevgisini nasib et!"
        ElseIf Today.Day = 5 Then
            lbl_Hadis.Text = "Allah'ın rızası, anne ve babanın rızasındadır. Allah'ın öfkesi de anne babanın öfkesindedir."
            lbl_Ayet.Text = "Rablerine karşı sorumluluk bilinci duyanlar da bölük bölük cennete gönderileceklerdir; oraya vardıklarında kapılarının ardına kadar açık olduğunu görecekler; ve muhafızlar onlara, Selam size! Hoş geldiniz! İşte buyrun, içinde temelli kalacağınız bu (cennete) girin! diyecekler.(Zümer, 73)"
            lbl_Dua.Text = "Nefsim, malım ve dinim üzerine Allah'ın adını okurum. Ey Allah! Beni senin kazana razı kıl ve hakkımda takdir edilen şeyleri bana mübarek kıl ki, geciktirdiğini acele göndermeni, peşin verdiğini de geciktirmeni istemeyeyim."
        ElseIf Today.Day = 6 Then
            lbl_Hadis.Text = "Dua, ibadetin özüdür."
            lbl_Ayet.Text = "Öyleyse yakınlarınıza, muhtaçlara ve yolculara haklarını verin; bu, Allah'ın rızasını kazanmak isteyenler için en doğrusudur: çünkü, mutluluğa erecekler onlardır! (Rum, 38) "
            lbl_Dua.Text = "Ey allah! Öncekilerden ve sonrakilerden her kime imandan neler verdiysen de benim ona gücüm ulaşmıyorsa, amelim eksik kalıyorsa, isteğim kavuşmuyorsa, duam yetişmiyorsa, öyle bir şey istemek dilime gelmiyorsa, sen  okuvvetli iman ile beni seçkin kıl. Ey acıyanların en merhametlisi kabul et! "
        ElseIf Today.Day = 7 Then
            lbl_Hadis.Text = "Nerede olursan ol Allah’a karşı gelmekten sakın; yaptığın kötülüğün arkasından bir iyilik yap ki bu onu yok etsin. İnsanlara karşı güzel ahlakın gereğine göre davran."
            lbl_Ayet.Text = "Görmediği halde Rahman'dan korkup O'na yönelen bir kalple gelen kimselere. Onlara denir ki: «İşte size vaad edilen bu cennet, Allah'a yönelen, O'nun emirlerine riayet eden, görmediği halde Rahman olan Allah'tan korkan ve O'na yönelen bir kalple gelenlere mahsustur. (Kaf, 32)"
            lbl_Dua.Text = "Ey Allah'ım Eyİnsanların Rabbbi! Bu hastalığı gider, şifa ver, şifa veren ancak Sensin. Senin şifandan başka hiçbir şifa yoktur. Oyle bir şifa ver ki hiçbir hastalık bırakmasın."
        ElseIf Today.Day = 8 Then
            lbl_Hadis.Text = "Allah, sizden birinizin yaptığı işi, ameli ve görevi  sağlam ve iyi yapmasından hoşnut olur."
            lbl_Ayet.Text = "Ve bilin ki, Allah'ın Elçisi aranızdadır. O, her işinizde ve her zaman sizin temayülünüze uysaydı, (toplum olarak) bundan zarar görürdünüz. Ama, görüldüğü gibi, Allah imanı(nızı) size sevdirdi, onu kalplerinizde güzelleştirdi ve hakikati inkar etmeyi, günah işlemeyi ve (güzel olan şeylere) karşı çıkmayı size çirkin gösterdi. İşte bunlar, doğru yönü izleyenlerdir. (Hucurat, 7)"
            lbl_Dua.Text = "Allah'ım, hususi ve umumi bütün kötülükleri bünyesinde toplayan habislerden sana sığınırım."
        ElseIf Today.Day = 9 Then
            lbl_Hadis.Text = "Sizden birinin, bir lokması düştüğünde onu alsın, temizleyip yesin, şeytana bırakmasın."
            lbl_Ayet.Text = "Buna karşılık, Rablerine karşı sorumluluklarının bilincinde olanlar, (öteki dünyada) üst üste bina edilmiş altından ırmaklar akan yüksek köşklere sahip olacaklardır: (Bu,) Allah'ın vaadi(dir); (ve) Allah vaadinden asla dönmez.(Zümer, 20)"
            lbl_Dua.Text = "Allah'ım; rızık olarak bize verdiğini bereketlendir, bizi ateş azabından muhafaza eyle. "
        ElseIf Today.Day = 10 Then
            lbl_Hadis.Text = "Kendisini ilgilendirmeyen şeyleri (mâlâyâniyi) terk etmesi, kişinin Müslümanlığının güzelliğindendir."
            lbl_Ayet.Text = "Rabbimiz Allah'tır deyip, sonra da doğrulukta devam edenlere gelince, onların üzerine melekler iner ve derler ki: Korkmayın, üzülmeyin, size vaad edilen cennetle sevinin. (Fussilet, 30)"
            lbl_Dua.Text = "Allahım, bana kendi katından hidâyet ihsân eyle, kendi fazlu kereminden bana ihsân eyle, rahmetini bana akıt ve bereketlerinden bana inzâl eyle."
        ElseIf Today.Day = 11 Then
            lbl_Hadis.Text = "İnsanların Allah'tan en uzak olanı, katı kalpli kimselerdir."
            lbl_Ayet.Text = "Sen ancak (ilahi) uyarıyı can kulağıyla dinleyen ve insan kavrayışının ötesinde bulunmasına rağmen Rahman'dan korkan kişiyi uyarabilirsin, işte böylelerine (Allah'ın) mağfiretini ve en güzel ödülü müjdele! (Yasin, 11) "
            lbl_Dua.Text = "Allahım! Kulun ve Resûlün Muhammed sallâllahü aleyhi ve sellemin senden istediği hayır ve iyilikleri senden ister ve sana sığınıp ilticâ ettiği her şeyden ben de sana sığınırım."
        ElseIf Today.Day = 12 Then
            lbl_Hadis.Text = "Doğru olmayan birşey gördüğünüzde veya işittiğinizde, insanların heybeti, hakkı söylemekten sizi alıkoymasın."
            lbl_Ayet.Text = "Çünkü, Allah'a ve O'nun Rasulü'ne itaat edenler, Allah'tan korkup O'na karşı sorumluluk duyanlar; işte bunlardır, (nihai) zafere erişecek olanlar! (Nur, 52)"
            lbl_Dua.Text = "Bildiğimiz-bilmediğimiz bütün iyilikleri ver, bildiğimiz-bilmediğimiz bütün kötülüklerden muhafaza et, her işimizin sonunu güzel eyle, dünya sıkıntılarından ve ahıret azabından bizi koru!"
        ElseIf Today.Day = 13 Then
            lbl_Hadis.Text = "Kim evlenirse imanın yarısını tamamlamış olur; kalan diğer yarısı hakkında ise Allah’tan korksun!"
            lbl_Ayet.Text = "Ey iman edenler! rükû edin, secdeye varın, Rabbinize kulluk edin, iyilik yapın ki kurtulabilesiniz. (Hac, 77)"
            lbl_Dua.Text = "Ya Rabbi, faydasız ilimden, makbul olmıyan ibâdetten ve kabul edilmiyen duâdan, acizlikten, tembellikten, korkaklıktan, cimrilikten ve her çeşit hastalıktan, gece ve gündüz gelecek kötülüklerden, sıkıntılardan kötü arkadaştan ve kötü komşudan sana sığınırım!"
        ElseIf Today.Day = 14 Then
            lbl_Hadis.Text = "Nikâh benim sünnetimdir. Kim benim sünnetimle amel etmezse, benden değildir. Evleniniz! Zira ben, diğer ümmetlere karşı sizin çokluğunuz ile iftihar edeceğim. Kimin maddî imkânı varsa, hemen evlensin. Kim maddî imkân bulamazsa, nafile oruç tutsun. Çünkü oruç, onun için şehveti kırıcıdır."
            lbl_Ayet.Text = "Rab'leri, onları kendi katından bir rahmet, bir rıza ve bir cennetle müjdeler ki o cennette onlar için bitmez tükenmez nimetler vardır. (Tevbe, 21)"
            lbl_Dua.Text = "Yâ Rabbî! Bana hayırlı işler yapmak, çirkin şeyleri terk etmek ve fakirleri sevmek nasip eyle! Kavmim arasında fitne çıkacağı zaman, fitneye karışmadan canımı al! Ya Rabbi, bana sevgini, seni sevenlerin sevgisini, sevgine yaklaştıracak amellerin sevgisini nasib et! "
        ElseIf Today.Day = 15 Then
            lbl_Hadis.Text = "Âmâ'ya veya yol sorana yol göstermen, sadakadır. Güçsüz birine yardım etmen, sadakadır. Konuşmakta güçlük çekenin meramını ifade edivermen sadakadır."
            lbl_Ayet.Text = "Gerçek şu ki, sadaka veren erkekler ile sadaka veren kadınlar ve Allah'a güzel bir borç verenler; onlar için kat kat arttırılır ve 'kerim (üstün ve onurlu)' olan ecir de onlarındır. (Hadid, 18)"
            lbl_Dua.Text = "Yâ Rabbî! Doğruyu bize doğru olarak göster ve ona uymağı bize nasip et ve yanlış, bozuk olan şeylerin yanlış olduklarını bize göster ve onlardan sakınmamızı nasip et!İnsanların en üstünü hurmetine bu duâmızı kabûl buyur!"
        ElseIf Today.Day = 16 Then
            lbl_Hadis.Text = "Kimin bir kız çocuğu dünyaya gelir de onu toprağa gömmeden, horlamadan ve üzerine erkek çocuğunu tercih etmeden yetiştirecek olursa Allah Teâlâ o kimseyi cennetine koyacaktır."
            lbl_Ayet.Text = "(O gün) zulmetmiş olan herkes, eğer yeryüzündeki her şeye sahip olsa, kendini kurtarmak için onu fidye verir. Azabı gördüklerinde, için için derin bir pişmanlık duyarlar. Onlara zulmedilmeksizin aralarında adaletle hükmedilir. (Yunus, 54)"
            lbl_Dua.Text = "Allah'ım, Senden evime hayırla girip hayırla çıkmamı istiyorum. Allahın adıyla girer, Allahın adıyla çıkarız. Rabbimiz Allah'a tevekkül ederiz."
        ElseIf Today.Day = 17 Then
            lbl_Hadis.Text = "Allah'tan korkunuz; çocuklarınız arasında adaletli davranınız."
            lbl_Ayet.Text = "Eğer yerde ve gökte Allah'tan başka ilahlar olsaydı kesinlikle ikisinin de düzeni bozulurdu. Demek ki, Arş'ın Rabbi Allah onların nitelemelerinden uzaktır, yücedir. (Enbiya, 22)"
            lbl_Dua.Text = "Ey Allah! Kalbime senden ümitli olma hissini at, senden gayri her şeyden gayri her şeyden umudumu keski, senin dışında kimseden bir şey beklemeyeyim."
        ElseIf Today.Day = 18 Then
            lbl_Hadis.Text = "Bir müslümanın diktiği ağaçtan veya ektiği ekinden insan, hayvan ve kuşların yedikleri şeyler, o müslüman için birer sadakadır."
            lbl_Ayet.Text = "Ey insanlar! Şüphesiz size Rabbinizden kesin bir delil geldi ve size apaçık bir nur indirdik.  (Nisâ 174)"
            lbl_Dua.Text = "Ey acayip işleri essiz olan Allah! Ceza gününe kadar bana hayırla rahmet et"
        ElseIf Today.Day = 19 Then
            lbl_Hadis.Text = "Nefsimi elinde bulundurana yemin ederim ki, sizden biriniz ben ona babasından, çocuğundan ve bütün insanlardan daha sevimli olmadıkça iman etmiş olamaz."
            lbl_Ayet.Text = "Biz, Kur’an’dan öyle bir şey indiriyoruz ki o, müminler için şifa ve rahmettir; zalimlerin ise yalnızca ziyanını artırır. (İsrâ 82)"
            lbl_Dua.Text = "Allah'ım, yıldızlar söndü, gözler kapandı. Sen ise hayat sahibi, daima duran ve tutansın. Seni ne bir uyuklama tutabilir, ne de bir uyku. Ey Hay olan Allah'ım, Kayyûm olan Allah'ım, gecemi rahat kıl gözlerimi kapatıver."
        ElseIf Today.Day = 20 Then
            lbl_Hadis.Text = "Ümmetimin fesada uğradığı bir anda benim bir sünnetime yapışan için şehit sevabı vardır."
            lbl_Ayet.Text = "Sizi Allah yarattı, sonra da vefat ettirecektir. İçinizden, (sahip oldukları) bilgiden hiçbir şeyi bilmeyecek yaşa, ömrün en düşkün çağına kadar yaşatılanlar da vardır. Kuşkusuz Allah ilim ve kudret sahibidir.(Nahl 70)"
            lbl_Dua.Text = "Ey Allah! Senin kolay kıldığından başka  bir kolay yoktur. Sen dilediğin zaman, zor olanı kolay ve yumuşak yaparsın."
        ElseIf Today.Day = 21 Then
            lbl_Hadis.Text = "Kim bana bir defa salavat-ı şerife okursa Allah Teala ona on salat eder."
            lbl_Ayet.Text = "Yaptığınız her harcamayı ve adadığınız her adağı muhakkak allah bilir. zalimler için hiç yardımcı yoktur.(Bakara, 270)"
            lbl_Dua.Text = "Allahım sen benim Rabbimsin. Senden başka ilâh yoktur. Sen beni yarattın. Ben de senin kulunum. Gücüm yettiği kadar senin va’din ve ahdin üzerineyim. Yaptıklarımın şerrinden sana sığınırım. Senin bana verdiğin ni’metini îtiraf ederim. Günahımı da îtiraf ederim. Beni mağfiret et. Çünkü günahları ancak sen bağışlarsın."
        ElseIf Today.Day = 22 Then
            lbl_Hadis.Text = "Her kul öldüğü hal üzere dirilir."
            lbl_Ayet.Text = "Göklerde ve yerde Allah'ın varlığını, birliğini, kudretini gösteren nice deliller vardır ki,insanlar yanından geçip gittikleri halde yüzlerini çevirdiklerinden farkına varmazlar.(Yusuf, 105)"
            lbl_Dua.Text = "Ya Rabbi, sana ve Resulüne itaat etmemizi ve bildirdiklerinle amel etmemizi nasip eyle!"
        ElseIf Today.Day = 23 Then
            lbl_Hadis.Text = "Ölüyü üç şey takip eder: Ailesi, malı ve ameli. İkisi geri döner; biri kalır: Ailesi ve malı geri döner; ameli ise kalır."
            lbl_Ayet.Text = " İnkar edenler, göklerle yer bitişik iken, bizim onları ayırdığımızı ve diri olan her şeyi sudan meydana getirdiğimizi görmediler mi? Hala inanmayacaklar mı? (Enbiya 30)"
            lbl_Dua.Text = "Bizi dostlarına dost, düşmanlarına düşman olanlardan ve sabreden ve şükredenlerden eyle!"
        ElseIf Today.Day = 24 Then
            lbl_Hadis.Text = "Namazda Fatiha suresini okumayan kimsenin namazı yoktur."
            lbl_Ayet.Text = "And olsun, eğer onlara, Gökleri ve yeri kim yarattı, güneşi ve ayı hizmetinize kim verdi? diye soracak olsan mutlaka, Allah diyeceklerdir. O halde nasıl (haktan) döndürülüyorlar? (Ankebut 61)"
            lbl_Dua.Text = "Yâ Rabbî! Kıldığım namazı kabûl eyle! Âhir ve âkıbetimi hayr eyle. Son nefesimde Kelime-i tevhîd söylememi nasîb eyle. Ölmüşlerimi afv ve magfiret eyle."
        ElseIf Today.Day = 25 Then
            lbl_Hadis.Text = "Alışveriş yapanlar meclisten ayrılmadıkları sürece muhayyerdirler. Eğer doğru konuşurlarsa alışverişlerinin bereketini görürler. Eğer bazı şeyleri saklarlarsa alışverişlerinin bereketi kaçar."
            lbl_Ayet.Text = "Ve onları kötülüklerden koru. O gün Sen, kimi kötülüklerden korumuşsan, gerçekten ona rahmet etmişsin. İşte büyük 'kurtuluş ve mutluluk' budur. (Mü'min 9)"
            lbl_Dua.Text = "Yâ Rabbî!.. Kendi sevgini, sevdiklerinin sevgisini, bütün enbiyânın, Ehl-i beytin, Eshâb-ı kirâmın ve bütün evliyâ-i kirâmın sevgisini ve sevgine kavuşturacak amel ve işleri nasip eyle!"
        ElseIf Today.Day = 26 Then
            lbl_Hadis.Text = "Kardeşinle (düşmanlığa varan) tertışmaya girme, onunla (kırıcı şekilde) şakalaşma ve ona yerine getiremeyeceğin sözü verme."
