    Private Function GetStringLength(ByVal str As String) As Integer
        Dim counter As Integer = 0
        Dim pos As Integer = 0
        Do While pos < str.Length
            If str.Chars(pos) <> ":"c Then
                counter += 1
            End If
            pos += 1
        Loop
        Return counter
    End Function
