    Private Sub sec_mdl_KeyDown(ByVal sender As Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles sec_mdl.KeyDown
        If e.KeyCode = Keys.Enter Then
            menu1()
            mn_2.Visible = False
            mn_3.Visible = False
        ElseIf e.KeyCode = Keys.Up Then
            mn_2.Visible = False
            mn_3.Visible = False
        ElseIf e.KeyCode = Keys.Tab Then
            menu1()
            mn_2.Visible = False
            mn_3.Visible = False
        ElseIf e.KeyCode = Keys.Down Then
            mn_2.Visible = False
            mn_3.Visible = False
        ElseIf e.KeyCode = Keys.Escape Then
            Me.Close()
        End If
        If e.KeyCode = Keys.NumPad1 Or e.KeyCode = Keys.D1 Then
            sec_mdl.SelectedIndex = 0
            menu1()
        ElseIf e.KeyCode = Keys.NumPad2 Or e.KeyCode = Keys.D2 Then
            sec_mdl.SelectedIndex = 1
            menu1()
        ElseIf e.KeyCode = Keys.NumPad3 Or e.KeyCode = Keys.D3 Then
