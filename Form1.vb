    Private Sub sec_menu2_KeyDown(ByVal sender As Object, ByVal e As System.Windows.Forms.KeyEventArgs) Handles sec_menu2.KeyDown
        If e.KeyCode = Keys.Escape Then
            mn_2.Visible = False
            mn_1.Focus()
            mn_1.Select()
            sec_menu1.Focus()
            sec_menu1.Select()
        ElseIf e.KeyCode = Keys.Enter Then
            menu_3()
            menu_mdl2()
        ElseIf e.KeyCode = Keys.Up Then
            If sec_menu2.SelectedIndex = 0 Then
                e.Handled = True
                sec_menu2.SelectedIndex = sec_menu2.Items.Count + 1
                sec_menu2.SelectedIndex = sec_menu2.Items.Count
            End If
        ElseIf e.KeyCode = Keys.Down Then
            Dim sayi = sec_menu2.Items.Count
            If sec_menu2.SelectedIndex = sec_menu2.Items.Count - 1 Then
                e.Handled = True
                sec_menu2.SelectedIndex = 0
            End If
        End If
        If e.KeyCode = Keys.NumPad1 Or e.KeyCode = Keys.D1 Then
            sec_menu2.SelectedIndex = 0
            menu_3()
            menu_mdl2()
        ElseIf e.KeyCode = Keys.NumPad2 Or e.KeyCode = Keys.D2 Then
