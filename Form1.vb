    Private Sub tbServisAVFisNo_kaydet_duzelt()
        Dim cmd As New OleDb.OleDbCommand
        Dim con As New OleDb.OleDbConnection
        cmd.Connection = con
        con.ConnectionString = connection
        If con.State = ConnectionState.Closed = True Then
            con.Open()
        End If
        cmd.CommandText = sorgu_query("sp_NebAlisverisSiraNoDuzelt")
        cmd.ExecuteNonQuery()
        con.Close()
        cmd = Nothing
        con = Nothing
        XtraMessageBox.Show(Sorgu_sDil("İşleminiz Başarıyla Tamamlandı...!", sDil), Sorgu_sDil("Dikkat", sDil), MessageBoxButtons.OK)
    End Sub
    Private Sub tbServisIndex()
        If yetki_kontrol(kullanici, "tbServisIndex") = True Then
            If XtraMessageBox.Show(Sorgu_sDil("Index Servis Bakım Hizmetini Başlatmak İstediğinize Emin misiniz...?", sDil) & vbCrLf & Sorgu_sDil("Servis Bakım Hizmetini Başlamadan Önce Yedek Almayı Unutmayınız...!", sDil), Sorgu_sDil("Dikkat", sDil), MessageBoxButtons.YesNo) = Windows.Forms.DialogResult.Yes Then
                bYedekle = True
                BeginSearch()
                Dim ds As New DataSet
                ds = sorgu(sorgu_query("select name from sysobjects where xtype='U' order by name"))
                Dim dr As DataRow
                Dim cmd As New OleDb.OleDbCommand
                Dim con As New OleDb.OleDbConnection
                cmd.Connection = con
                con.ConnectionString = connection
                For Each dr In ds.Tables(0).Rows
                    If con.State = ConnectionState.Closed = True Then
                        con.Open()
                    End If
                    'cmd.CommandText = sorgu_query("dbcc dbreindex(N'[dbo].[" & dr("name") & "]', N'', 90, sorted_data_reorg)")
                    cmd.CommandText = sorgu_query("dbcc dbreindex(N'[dbo].[" & dr("name") & "]', N'', 90)")
                    cmd.ExecuteNonQuery()
                Next
                If con.State = ConnectionState.Closed = True Then
                    con.Open()
                End If
                cmd.CommandText = sorgu_query("DBCC shrinkdatabase(N'" & sDatabaseGenel & "', 10,  TRUNCATEONLY )")
                cmd.ExecuteNonQuery()
                cmd.CommandText = sorgu_query("DBCC SQLPERF(LOGSPACE)")
                cmd.ExecuteNonQuery()
                con.Close()
                cmd = Nothing
                con = Nothing
                XtraMessageBox.Show(Sorgu_sDil("İşleminiz Başarıyla Tamamlandı...!", sDil))
            End If
        End If
