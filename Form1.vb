    Private Sub sinif_kaydet_yeni(ByVal sSinifKodu As String, ByVal sAciklama As String, ByVal sinifno As Integer, ByVal t As String, Optional ByVal sDatabase As String = "")
        Dim use As String = ""
        If sDatabase <> "" Then
            use = "USE " & sDatabase
        End If
        Dim con As New OleDb.OleDbConnection
        Dim cmd As New OleDb.OleDbCommand
        cmd.Connection = con
        con.ConnectionString = connection
        If con.State = ConnectionState.Closed = True Then
            con.Open()
        End If
        If t = "M" Then
            cmd.CommandText = sorgu_query("" & use & " INSERT INTO tb" & t & "Sinif" & sinifno & "                       (sSinifKodu, sAciklama,bSatisYapilamaz) VALUES     ('" & sSinifKodu & "', '" & sAciklama & "',0)")
        Else
            cmd.CommandText = sorgu_query("" & use & " INSERT INTO tb" & t & "Sinif" & sinifno & "                       (sSinifKodu, sAciklama) VALUES     ('" & sSinifKodu & "', '" & sAciklama & "')")
        End If
        Try
            cmd.ExecuteNonQuery()
        Catch ex As Exception
        End Try
        con.Close()
        con = Nothing
        cmd = Nothing
    End Sub
