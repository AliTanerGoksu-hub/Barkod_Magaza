            Dim satir = GridView6.FocusedRowHandle
            Dim dr As DataRow = GridView6.GetDataRow(GridView6.FocusedRowHandle)
            frm.kayitno = dr("ID")
            frm.status = True
            frm.kullanici = kullanici
            If yetki_kontrol(kullanici, frm.Name) = True Then
