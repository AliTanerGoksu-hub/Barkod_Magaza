    Private Sub sDepo_toplu()
        Dim frm As New frm_tbKod() With {.firmano = firmano, .donemno = donemno, .connection = connection, .sText = "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED SELECT     sDepo as sKod,sAciklama as sAciklama FROM         tbDepo", .bDepo = True}
        frm.lbl_sKod.Text = "Depo:"
        If frm.ShowDialog() = Windows.Forms.DialogResult.OK Then
            If XtraMessageBox.Show(frm.LookUpEdit1.EditValue & " Kodlu Depoda Çalışmak İstediğinize Emin misiniz...?", Sorgu_sDil("Dikkat", sDil), MessageBoxButtons.YesNo, MessageBoxIcon.Question) = Windows.Forms.DialogResult.Yes Then
                Registry.CurrentUser.CreateSubKey("Software").CreateSubKey("BusinessSmart").CreateSubKey("MAGAZA").SetValue("DEPOKODU", frm.LookUpEdit1.EditValue)
                sDepo = frm.LookUpEdit1.EditValue
                If frm.sec_sHareketTipi.Checked = True Then
                    sHareketTipi = Microsoft.VisualBasic.Right(Trim(frm.LookUpEdit1.EditValue), 3)
                End If
                If frm.sec_sSubeMagaza.Checked = True Then
                    sSubeMagaza = Microsoft.VisualBasic.Right(Trim(frm.LookUpEdit1.EditValue), 3) & " "
                End If
                If frm.sec_sAktifFiyatTipi.Checked = True Then
                    Try
                        sAktifFiyatTipi = CInt(Microsoft.VisualBasic.Right(Trim(frm.LookUpEdit1.EditValue), 2))
                    Catch ex As Exception
                    End Try
                End If
                XtraMessageBox.Show("Tamamlandı" & vbCrLf & "Aktif Depo :" & sDepo, Sorgu_sDil("Dikkat", sDil), MessageBoxButtons.OK, MessageBoxIcon.Information)
            End If
        End If
    End Sub
