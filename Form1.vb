    Private Sub gorunum_degistir(ByVal style As String)
        If style = "Flat" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.Flat
            FastReportSet.UseOffice2007Form = False
            FastReportSet.UIStyle = FastReport.Utils.UIStyle.VistaGlass
        ElseIf style = "Ultra Flat" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.UltraFlat
        ElseIf style = "Style 3D" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.Style3D
            FastReportSet.UseOffice2007Form = False
            FastReportSet.UIStyle = FastReport.Utils.UIStyle.VisualStudio2005
        ElseIf style = "Office 2003" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.Office2003
            FastReportSet.UseOffice2007Form = False
            FastReportSet.UIStyle = FastReport.Utils.UIStyle.Office2003
        ElseIf style = "Caramel" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.Skin
            DefaultLookAndFeel1.LookAndFeel.SkinName = "Caramel"
        ElseIf style = "Black" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.Skin
            DefaultLookAndFeel1.LookAndFeel.SkinName = "Black"
            FastReportSet.UseOffice2007Form = True
            FastReportSet.UIStyle = FastReport.Utils.UIStyle.Office2007Black
        ElseIf style = "Blue" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.Skin
            DefaultLookAndFeel1.LookAndFeel.SkinName = "Blue"
            FastReportSet.UseOffice2007Form = True
            FastReportSet.UIStyle = FastReport.Utils.UIStyle.Office2007Blue
        ElseIf style = "Office 2007 Black" Then
            DefaultLookAndFeel1.LookAndFeel.Style = DevExpress.LookAndFeel.LookAndFeelStyle.Skin
