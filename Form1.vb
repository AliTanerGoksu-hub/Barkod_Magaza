            Dim dr As DataRow = GridView6.GetDataRow(GridView6.FocusedRowHandle)
            Dim satir = GridView6.FocusedRowHandle
            gorev_kayit_sil(dr("ID"))
            ara_gorev()
            GridView6.FocusedRowHandle = satir
            satir = Nothing
            grd_ajanda.Focus()
            grd_ajanda.Select()
        End If
    End Sub
    Private Sub gorev_kayit_sil(ByVal ID As Int64)
        Dim cmd As New OleDb.OleDbCommand
        Dim con As New OleDb.OleDbConnection
        con.ConnectionString = connection
        cmd.Connection = con
        con.ConnectionString = connection
        cmd.Connection = con
        If con.State = ConnectionState.Closed Then
            con.Open()
        End If
        cmd.CommandText = sorgu_query("SET DATEFORMAT DMY DELETE FROM aEmirAjanda WHERE ID = '" & ID & "'")
        cmd.ExecuteNonQuery()
        con.Close()
    End Sub
    Private Sub Lisans_tarih_kontrol(ByVal lisansSorSonra As String)
        Dim cmd As New OleDb.OleDbCommand
        Dim con As New OleDb.OleDbConnection
        con.ConnectionString = connection
        cmd.Connection = con
        con.ConnectionString = connection
        cmd.Connection = con
        If con.State = ConnectionState.Closed Then
            con.Open()
        End If
        cmd.CommandText = sorgu_query("select TOP 1 dteupdatedate from tbParamGenel")
        cmd.ExecuteNonQuery()
        LisansKont = cmd.ExecuteScalar
        If LisansKont >= Today Then
            lisansSorSonra = True
        Else
            lisansSorSonra = False
        End If
        con.Close()
    End Sub
    Private Sub Lisans_tarih_Update(ByVal Today As String, dteGecerlilikTarihi As Date)
        Dim YeniTarih As Date
        Dim EklenecekSure As Integer
        Dim cmd As New OleDb.OleDbCommand
        Dim con As New OleDb.OleDbConnection
        con.ConnectionString = connection
        cmd.Connection = con
        con.ConnectionString = connection
        cmd.Connection = con
        If dteGecerlilikTarihi >= Today Then
            EklenecekSure = 2
            YeniTarih = DateAdd("d", EklenecekSure, Today)
            If con.State = ConnectionState.Closed Then
                con.Open()
            End If
            cmd.CommandText = sorgu_query("set dateformat dmy update tbParamGenel  set dteupdatedate ='" & YeniTarih & "'")
            cmd.ExecuteNonQuery()
            LisansKont = cmd.ExecuteScalar
            If LisansKont >= Today Then
                lisansSorSonra = True
            Else
                lisansSorSonra = False
            End If
        End If
        con.Close()
    End Sub
