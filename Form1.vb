    Sub information()
        If Trim(Now.ToLongTimeString) = "00:00:59" Then
            dteSistemTarihi = Today
            license()
        End If
        If lockTimerCounter = 0 Then
            lockTimerCounter += 1
            UpdateTime()
            lockTimerCounter -= 1
        End If
        If Today > "21/01/2010" Then
            If bLicenseKontrol = False Then
                'If bCrack = True Then
                '    bLicenseKontrol = True
                'license() YOK
                'End If
            End If
        End If
        lbl_logo.Text = sFirmaAdi
        'lbl_Firma.Text = sDatabaseGenel & vbNewLine & "Lisans Sahibi" & vbNewLine & sFirmaAdi
        lbl_user.Text = kasiyer
        'lbl_lisans.Text = "<marquee align='middle' scrollamount='1' height='30' width='100%' direction='up'scrolldelay='1'>" & sOnayKodu & "-" & lisansNo & "</marquee>"
        lbl_lisans.Caption = "Lisans: " & sOnayKodu & "-" & lisansNo
        lbl_Tarih.Text = Now.ToLongDateString
        Me.Text = "Business Smart© [" & sDatabaseGenel & "]" & " Depo:[" & sDepo & "]" & " [" & kasiyer & "]" & sLisansUyari
        'BarStaticItem3.Caption = "Tarih:  " & Now.ToLongDateString & " Saat: " & Now.ToLongTimeString
        BarStatic_S.Caption = Now.ToLongDateString & " " & Now.ToLongTimeString
        BarStatic_P.Caption = "[" & sDatabaseGenel & "]"
        BarStatic_T.Caption = "[" & kasiyer & "]"
        BarStatic_sDepo.Caption = "[Depo: " & sDepo & "]"
        If dteSistemTarihi = Today Then
            BarStatic_dteIslemTarihi.Caption = "[İşlemTarihi: " & dteSistemTarihi & " ]"
            BarStatic_dteIslemTarihi.Visibility = DevExpress.XtraBars.BarItemVisibility.Never
        Else
            BarStatic_dteIslemTarihi.Visibility = DevExpress.XtraBars.BarItemVisibility.Always
            BarStatic_dteIslemTarihi.Caption = "[İşlemTarihi: " & dteSistemTarihi & " ]"
        End If
        BarStatic_sKasa.Caption = "[Kasa:" & sSubeMagaza & "]"
        BarStatic_LastBackup.Caption = "[SonYedek:" & dteSonYedekTarihi & " ]"
        BarStatic_sAktifFiyatTipi.Caption = "[AF:" & sAktifFiyatTipi & "]"
        lbl_kisitli.Text = dteSistemTarihi
        If dteSistemTarihi <> Today Then
            lbl_kisitli.Text = "[İşlemTarihi : " & dteSistemTarihi & " ]"
            If nKayitSinir = 0 Then
                lbl_kisitli.Visible = True
            End If
        Else
            If nKayitSinir > 0 Then
                lbl_kisitli.Text = "*Kısıtlı Kullanım*"
                lbl_kisitli.Visible = True
            Else
                lbl_kisitli.Text = dteSistemTarihi
                lbl_kisitli.Visible = False
            End If
        End If
        'If lbl_kisitli.Visible = False Then
        '    lbl_kisitli.Visible = True
        'ElseIf lbl_kisitli.Visible = True Then
        '    lbl_kisitli.Visible = False
        'End If
        If Not ActiveMDIForm Is Nothing Then
            If sec_mdl.Focused = True Then
                mdl = 0
            ElseIf sec_menu1.Focused = True Then
                mdl = 1
            ElseIf sec_menu2.Focused = True Then
                mdl = 2
            ElseIf sec_menu3.Focused = True Then
