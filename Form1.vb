    Private Sub tbYetkiIndex()
        If yetki_kontrol(kullanici, "tbYetkilendirmeIndex") = True Then
            If XtraMessageBox.Show(Sorgu_sDil("Yetkilendirme Servis Bakım Hizmetini Başlatmak İstediğinize Emin misiniz...?", sDil) & vbCrLf & Sorgu_sDil("Servis Bakım Hizmetini Başlamadan Önce Yedek Almayı Unutmayınız...!", sDil), Sorgu_sDil("Dikkat", sDil), MessageBoxButtons.YesNo) = Windows.Forms.DialogResult.Yes Then
                Dim ds As New DataSet
                Dim dr As DataRow
                Dim cmd As New OleDb.OleDbCommand
                Dim con As New OleDb.OleDbConnection
                cmd.Connection = con
                con.ConnectionString = connection
                Try
                    ds = sorgu(sorgu_query("SET DATEFORMAT DMY SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED SELECT     PersonelNo, Form, COUNT(IND) AS nSayi, MIN(IND) AS IND FROM         aPersonelYetki GROUP BY PersonelNo, Form HAVING      (COUNT(IND) > 1) ORDER BY PersonelNo"))
                    For Each dr In ds.Tables(0).Rows
                        If con.State = ConnectionState.Closed = True Then
                            con.Open()
                        End If
                        cmd.CommandText = sorgu_query("SET DATEFORMAT DMY SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED Delete aPersonelYetki Where PersonelNo = " & dr("PersonelNo") & " AND Form = '" & dr("Form") & "' AND IND NOT IN (" & dr("IND") & ")")
                        cmd.ExecuteNonQuery()
                    Next
                Catch ex As Exception
                End Try
                ds = sorgu(sorgu_query("SET DATEFORMAT DMY SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED SELECT     Form, COUNT(IND) AS nSayi, MIN(IND) AS IND FROM         aEmirForms GROUP BY Form HAVING      (COUNT(IND) > 1) ORDER BY Form"))
                For Each dr In ds.Tables(0).Rows
                    If con.State = ConnectionState.Closed = True Then
                        con.Open()
                    End If
                    cmd.CommandText = sorgu_query("SET DATEFORMAT DMY SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED Delete aEmirForms Where  Form = '" & dr("Form") & "' AND IND NOT IN (" & dr("IND") & ")")
                    cmd.ExecuteNonQuery()
                Next
                If con.State = ConnectionState.Closed = True Then
                    con.Open()
                End If
                con.Close()
                cmd = Nothing
                con = Nothing
                XtraMessageBox.Show(Sorgu_sDil("İşleminiz Başarıyla Tamamlandı...!", sDil))
            End If
        End If
    End Sub
