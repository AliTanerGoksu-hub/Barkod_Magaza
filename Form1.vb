    Private Sub dil_degistir(ByVal Dil As String)
        Me.WindowState = FormWindowState.Minimized
        Me.Hide()
        If Not ActiveMDIForm Is Nothing Then ActiveMDIForm.Close()
        Dim frm As New Form1
        Dim con As New OleDb.OleDbConnection
        Dim cmd As New OleDb.OleDbCommand
        frm.kasiyer = kasiyer
        frm.kullanici = kullanici
        'frm.SQLconnection = SQLconnection
        connection = connection
        cmd.Connection = con
        con.ConnectionString = connection
        If con.State = ConnectionState.Closed = True Then
            con.Open()
        End If
        cmd.CommandText = sorgu_query("update TOP(1) tbParamGenel set sDil ='" + Dil + "'")
        cmd.ExecuteNonQuery()
        sDil = Dil

        con.Close()

        frm.Show()
        Me.Dispose()
    End Sub
