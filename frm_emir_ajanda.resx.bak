  </metadata>
  <data name="OleDbSelectCommand1.CommandText" xml:space="preserve">
    <value>SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED SELECT ID, FirmaNo, PersonelNo, Status, Subject, Description, Label, StartTime, EndTime, Location, AllDay, EventType, RecurrenceInfo, ReminderInfo FROM aEmirAjanda</value>
  </data>
