  </metadata>
  <data name="OleDbUpdateCommand1.CommandText" xml:space="preserve">
    <value>UPDATE aEmirAjanda SET FirmaNo = ?, PersonelNo = ?, Status = ?, Subject = ?, Description = ?, Label = ?, StartTime = ?, EndTime = ?, Location = ?, AllDay = ?, EventType = ?, RecurrenceInfo = ?, ReminderInfo = ? WHERE (ID = ?) AND (AllDay = ? OR ? IS NULL AND AllDay IS NULL) AND (EndTime = ? OR ? IS NULL AND EndTime IS NULL) AND (EventType = ? OR ? IS NULL AND EventType IS NULL) AND (FirmaNo = ? OR ? IS NULL AND FirmaNo IS NULL) AND (Label = ? OR ? IS NULL AND Label IS NULL) AND (Location = ? OR ? IS NULL AND Location IS NULL) AND (PersonelNo = ? OR ? IS NULL AND PersonelNo IS NULL) AND (StartTime = ? OR ? IS NULL AND StartTime IS NULL) AND (Status = ? OR ? IS NULL AND Status IS NULL) AND (Subject = ? OR ? IS NULL AND Subject IS NULL); SELECT ID, FirmaNo, PersonelNo, Status, Subject, Description, Label, StartTime, EndTime, Location, AllDay, EventType, RecurrenceInfo, ReminderInfo FROM aEmirAjanda WHERE (ID = ?)</value>
  </data>
