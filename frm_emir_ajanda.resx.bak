  <data name="con.ConnectionString" xml:space="preserve">
    <value>User ID=sa;Data Source="192.168.0.1";Tag with column collation when possible=False;Initial Catalog=UGURLU;Use Procedure for Prepare=1;Auto Translate=True;Persist Security Info=False;Provider="SQLOLEDB.1";Workstation ID=SERVERR;Use Encryption for Data=False;Packet Size=4096</value>
  </data>
