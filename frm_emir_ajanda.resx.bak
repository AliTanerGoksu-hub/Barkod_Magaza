  <data name="OleDbInsertCommand1.CommandText" xml:space="preserve">
    <value>INSERT INTO aEmirAjanda(FirmaNo, PersonelNo, Status, Subject, Description, Label, StartTime, EndTime, Location, AllDay, EventType, RecurrenceInfo, ReminderInfo) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?); SELECT ID, FirmaNo, PersonelNo, Status, Subject, Description, Label, StartTime, EndTime, Location, AllDay, EventType, RecurrenceInfo, ReminderInfo FROM aEmirAjanda WHERE (ID = @@IDENTITY)</value>
  </data>
