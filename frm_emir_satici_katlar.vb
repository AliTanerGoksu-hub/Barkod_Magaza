    Private Sub odemesekli_baglanti_kaydet_yeni(ByVal sSaticiRumuzu As String, ByVal sAdi As String, ByVal sSoyadi As String, ByVal sKat As String)
        Dim con As New OleDb.OleDbConnection
        Dim cmd As New OleDb.OleDbCommand
        cmd.Connection = con
        con.ConnectionString = connection
        cmd.CommandTimeout = Nothing
        If con.State = ConnectionState.Closed = True Then
            con.Open()
        End If
        cmd.CommandText = sorgu_query("SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED INSERT INTO tbSaticiKatlari                        (sSaticiRumuzu, sAdi, sSoyadi, sKat) VALUES     ('" & sSaticiRumuzu & "', '" & sAdi & "', '" & sSoyadi & "', '" & sKat & "')")
        cmd.ExecuteNonQuery()
        con.Close()
    End Sub
