            con.Open()
        End If
        cmd.CommandText = sorgu_query("SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED UPDATE    tbSaticiKatlari SET            sKat = '" & sKat & "' WHERE sSaticiRumuzu = '" & sSaticiRumuzu & "'")
