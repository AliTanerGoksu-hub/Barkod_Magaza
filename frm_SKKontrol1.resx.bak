  <data name="Label1.Text" xml:space="preserve">
    <value>Müşteriye Yapılan Satışlar Sol Tarafta, Yapılan satışların Detayı Ortada vede Satışa yapılan taksitler sağ taraftadır. Detayını Takip etmek istediğiniz Satış sol bölümden seçebilirsiniz. İşlemi Tamamlamak İçin [Tamam] İşlemden Çıkmak İçin ise [Vazgeç] butonuna tıklayınız...</value>
  </data>
  <assembly alias="System.Drawing" name="System.Drawing, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />
